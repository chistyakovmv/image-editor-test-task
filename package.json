    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "cropperjs": "^1.6.2",
    "pinia": "^3.0.3",
    "vue": "^3.5.17",
    "vuetify": "^3.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.0.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.2.10"
  }
}
